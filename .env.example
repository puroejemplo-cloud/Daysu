# Copia este archivo a .env y rellena los valores reales

# ── Base de datos ────────────────────────────────────────────────────────────
# Local Docker (ver docker-compose.yml)
DATABASE_URL="postgresql://eventmaster:eventmaster123@localhost:5432/eventmaster_pro?schema=public"

# Neon (Vercel Marketplace) — se llena automáticamente al añadir la integración Neon
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""   # conexión directa para migraciones

# ── Auth ─────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="cadena-aleatoria-larga-min-32-caracteres"
# URL base de la app — REQUERIDO en producción (usada en redirecciones de Stripe y auth)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── Cron ─────────────────────────────────────────────────────────────────────
# Protege /api/cron/expire-holds — REQUERIDO si CRON_SECRET está definida
CRON_SECRET="cadena-aleatoria"

# ── Stripe ───────────────────────────────────────────────────────────────────
# REQUERIDO — la app no inicia pagos sin estas variables
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# REQUERIDO para la galería pública — se llena desde el panel de Vercel Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Google Places (opcional) ─────────────────────────────────────────────────
# Si no se configura, la homepage usa un fallback de reseñas estáticas
GOOGLE_PLACES_API_KEY="AIza..."
GOOGLE_PLACE_ID="ChIJ..."

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID — se obtiene en analytics.google.com
# Solo se carga en producción (NODE_ENV=production)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
