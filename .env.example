# Copia este archivo a .env y rellena los valores reales

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:5432/eventmaster_pro?schema=public"

# NextAuth — genera con: openssl rand -base64 32
AUTH_SECRET="cadena-aleatoria-larga-min-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# Cron job (protege el endpoint /api/cron/expire-holds en producción)
CRON_SECRET="cadena-aleatoria"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Google Places API — reseñas en la homepage (opcional, se usa fallback estático si no se configura)
GOOGLE_PLACES_API_KEY="AIza..."
GOOGLE_PLACE_ID="ChIJ..."
